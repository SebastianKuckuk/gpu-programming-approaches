Bootstrap: docker
From: nvcr.io/nvidia/nvhpc:25.7-devel-cuda12.9-ubuntu24.04

%runscript
    batchspawner-singleuser jupyterhub-singleuser


%apprun jupyter-lab
    jupyter lab --no-browser --ip 0.0.0.0 --port 1337


%environment
    export http_proxy=http://proxy.nhr.fau.de:80
    export https_proxy=http://proxy.nhr.fau.de:80
    export HTTP_PROXY=http://proxy.nhr.fau.de:80
    export HTTPS_PROXY=http://proxy.nhr.fau.de:80

    source "/root/conda/etc/profile.d/conda.sh"

    conda config --append envs_dirs /root/conda-env
    conda activate gpu-courses


%post
    # update installed packages
    apt update
    apt dist-upgrade -y


    # install basic packages
    apt install -y cmake \
                    pkg-config \
                    build-essential \
                    gpg-agent \
                    wget \
                    curl


    # install RDMA package
    apt install -y rdma-core 

    # install editors
    apt install -y less vim emacs nano


    # set up conda
    cd /root
    wget -O Miniforge3.sh "https://github.com/conda-forge/miniforge/releases/latest/download/Miniforge3-$(uname)-$(uname -m).sh"
    bash Miniforge3.sh -b -p "/root/conda"
    . "/root/conda/etc/profile.d/conda.sh"
    conda update -n base -c conda-forge conda -y


    # set up conda environment
    conda create -c conda-forge -p /root/conda-env/gpu-courses -y
    conda config --append envs_dirs /root/conda-env
    conda activate gpu-courses


    # install basic Python packages
    conda install -y sympy \
                    pandas \
                    matplotlib

    # add jupyter hub / lab / nb + batchspawner
    conda install -y jupyterhub=5.4.3 \
                    jupyterlab=4.5.3 \
                    notebook=7.5.3 \
                    batchspawner

    # add jupyter extensions
    conda install -y jupyterlab-git \
                    jupyterlab-spellchecker \
                    jupyter-resource-usage \
                    jupyterlab_code_formatter \
                    black \
                    isort \
                    jupyter-lsp \
                    jupyterlab-lsp \
                    jedi-language-server


    # set up apex generator dependencies
    apt install -y clang-format
    conda install -y sympy pandas matplotlib openpyxl


    # set up adaptive cpp
    # install adaptive cpp prerequisites
    cd /root
    apt install -y libboost-all-dev
    apt install -y lsb-release wget software-properties-common gnupg2
    wget https://apt.llvm.org/llvm.sh
    chmod +x llvm.sh
    ./llvm.sh 18 # set up repositories for clang 18
    rm llvm.sh
    apt install -y libclang-dev clang-tools libomp-dev llvm-dev clang lld

    export GCC_VERSION=$(clang++ -v 2>&1 | awk -F/ '/Selected GCC/ {print $NF}')
	apt install -y "libstdc++-${GCC_VERSION}-dev"
    apt install -y "g++-${GCC_VERSION}"

    # build and install adaptive cpp
    cd /root

    git clone --recurse-submodules https://github.com/AdaptiveCpp/AdaptiveCpp
    cd AdaptiveCpp
    mkdir build && cd build
    cmake ..
    make install -j

    # clean up
    cd /root
    rm -r AdaptiveCpp


    # set up Kokkos ...
    cd /root
    git clone --depth=2 --branch 5.0.2 https://github.com/kokkos/kokkos.git
    cd kokkos

    #   ... serial
    mkdir build-serial && cd build-serial
    cmake .. -DCMAKE_CXX_COMPILER=g++ -DCMAKE_INSTALL_PREFIX=/root/kokkos/install-serial -DKokkos_ARCH_NATIVE=ON
    make -j && make install
    cd ..

    #   ... CPU parallel
    mkdir build-omp && cd build-omp
    cmake .. -DCMAKE_CXX_COMPILER=g++ -DCMAKE_INSTALL_PREFIX=/root/kokkos/install-omp -DKokkos_ENABLE_OPENMP=ON -DKokkos_ARCH_NATIVE=ON
    make -j && make install
    cd ..

    #   ... CUDA
    mkdir build-cuda-80 && cd build-cuda-80
    cmake .. -DCMAKE_CXX_COMPILER=/root/kokkos/bin/nvcc_wrapper -DCMAKE_INSTALL_PREFIX=/root/kokkos/install-cuda-80 -DKokkos_ENABLE_CUDA=ON -DKokkos_ENABLE_CUDA_LAMBDA=ON -DKokkos_ARCH_AMPERE80=ON -DKokkos_ARCH_NATIVE=ON
    make -j && make install
    cd ..

    mkdir build-cuda-86 && cd build-cuda-86
    cmake .. -DCMAKE_CXX_COMPILER=/root/kokkos/bin/nvcc_wrapper -DCMAKE_INSTALL_PREFIX=/root/kokkos/install-cuda-86 -DKokkos_ENABLE_CUDA=ON -DKokkos_ENABLE_CUDA_LAMBDA=ON -DKokkos_ARCH_AMPERE86=ON -DKokkos_ARCH_NATIVE=ON
    make -j && make install
    cd ..

    mkdir build-cuda-90 && cd build-cuda-90
    cmake .. -DCMAKE_CXX_COMPILER=/root/kokkos/bin/nvcc_wrapper -DCMAKE_INSTALL_PREFIX=/root/kokkos/install-cuda-90 -DKokkos_ENABLE_CUDA=ON -DKokkos_ENABLE_CUDA_LAMBDA=ON -DKokkos_ARCH_HOPPER90=ON -DKokkos_ARCH_NATIVE=ON
    make -j && make install
    cd ..


    # configure shortcuts
    echo "alias ll='ls -alF'" > /etc/profile.d/alias.sh
